{
  "manifest_version": 3,
  "name": "Mosaïque",
  "version": "0.1.0",
  "description": "Onglets, favoris et notes en vue mosaïque sur la page Nouvel onglet.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": ["tabs", "bookmarks", "storage", "favicon"],
  "icons": {
    "16": "favicon.svg",
    "48": "favicon.svg",
    "128": "favicon.svg"
  }
}

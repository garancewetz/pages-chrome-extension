{
  "manifest_version": 3,
  "name": "Pages",
  "version": "1.0.0",
  "description": "Mes onglets et mes favoris réunis sur la page Nouvel onglet.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": ["tabs", "bookmarks", "favicon"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
